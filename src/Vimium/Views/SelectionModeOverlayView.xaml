<local:ForegroundWindow
    x:Class="Vimium.Views.SelectionModeOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Vimium.Views"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    AllowsTransparency="True"
    Topmost="True"
    ShowActivated="False"
    Loaded="SelectionModeOverlayView_OnLoaded"
    Closed="SelectionModeOverlayView_OnClosed">
    <local:ForegroundWindow.Background>
        <SolidColorBrush Color="Transparent" />
    </local:ForegroundWindow.Background>
    <Grid>
        <!-- Canvas for match highlights, positioned absolutely from code-behind -->
        <Canvas x:Name="layoutCanvas" Background="Transparent" />

        <!-- Search bar at bottom of overlay (always visible while active) -->
        <Border x:Name="SearchBar"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="{DynamicResource FindSearchBarBackgroundBrush}"
                CornerRadius="6"
                Padding="12,6"
                Margin="0,0,0,60"
                MinWidth="220">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- Search query display (read-only; keyboard hook drives input) -->
                    <TextBlock x:Name="SearchQueryText"
                               Foreground="{DynamicResource FindSearchBarForegroundBrush}"
                               FontSize="16"
                               FontFamily="Segoe UI, Consolas, monospace"
                               VerticalAlignment="Center"
                               MinWidth="100" />
                    <!-- Blinking cursor in search bar -->
                    <Border x:Name="SearchCursor"
                            Width="1.5"
                            Height="18"
                            Background="{DynamicResource FindSearchBarForegroundBrush}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                    <!-- Loading spinner (visible while IsSearching) -->
                    <TextBlock x:Name="LoadingSpinner"
                               Text="⏳"
                               Foreground="{DynamicResource FindSearchBarCountBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Visibility="Collapsed" />
                    <!-- Match count label -->
                    <TextBlock x:Name="MatchCountLabel"
                               Foreground="{DynamicResource FindSearchBarCountBrush}"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Text="" />
                </StackPanel>
                <!-- Timeout / status tip (visible when SearchTimedOut is true) -->
                <TextBlock x:Name="StatusTipLabel"
                           Foreground="{DynamicResource FindSearchBarCountBrush}"
                           FontSize="10"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,4,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </Grid>
</local:ForegroundWindow>
