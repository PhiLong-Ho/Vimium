<local:ForegroundWindow
    x:Class="Vimium.Views.OverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Vimium.Views"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    AllowsTransparency="True"
    Topmost="True"
    ShowActivated="False"
    Loaded="OverlayView_OnLoaded"
    Closed="OverlayView_OnClosed">
    <local:ForegroundWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="LeaderLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="Opacity" Value="0.8" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Active}" Value="false">
                    <Setter Property="Stroke" Value="{Binding DataContext.HintInactiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Background" Value="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
            <Setter Property="Foreground" Value="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
            <Setter Property="Padding" Value="2,0,2,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Active}" Value="false">
                    <Setter Property="Background" Value="{Binding DataContext.HintInactiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </local:ForegroundWindow.Resources>
    <local:ForegroundWindow.Background>
        <SolidColorBrush Color="Transparent" />
    </local:ForegroundWindow.Background>
    <Grid x:Name="layoutGrid" Background="Transparent" MouseDown="Overlay_MouseDown">
        <TextBox x:Name="MatchStringControl" IsReadOnly="True" IsHitTestVisible="False" Width="50" VerticalAlignment="Bottom" Background="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" Foreground="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" FontWeight="Bold" FontFamily="Segoe UI, Helvetica, Arial" />
        <!-- Loading indicator: shown while hints are being enumerated on a background thread -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}"
                CornerRadius="3"
                Padding="12,8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="LoadingIcon"
                       Width="20" Height="20"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
                <TextBlock x:Name="LoadingIndicator"
                           Text="Generating hints…"
                           Foreground="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}"
                           FontSize="16"
                           FontWeight="Bold"
                           FontFamily="Segoe UI, Helvetica, Arial">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="TextBlock.Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.3" Duration="0:0:0.6" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </StackPanel>
        </Border>
        <ItemsControl ItemsSource="{Binding Hints}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsItemsHost="True" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style>
                    <Setter Property="Canvas.Top" Value="{Binding AdjustedTop}" />
                    <Setter Property="Canvas.Left" Value="{Binding AdjustedLeft}" />
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <!-- Leader line: connects label back to element center when offset by collision -->
                        <Line X1="{Binding LineX1}" Y1="{Binding LineY1}"
                              X2="{Binding LineX2}" Y2="{Binding LineY2}"
                              Style="{StaticResource LeaderLineStyle}"
                              Visibility="{Binding ShowLeaderLine, Converter={StaticResource BoolToVisibility}}" />
                        <!--<Rectangle Width="{Binding Hint.BoundingRectangle.Width}" Height="{Binding Hint.BoundingRectangle.Height}" Stroke="Red" StrokeDashArray="1 2">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="Yellow" Opacity="0.05" />
                            </Rectangle.Fill>
                        </Rectangle>-->
                        <Viewbox StretchDirection="DownOnly" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,1,2,1" MinWidth="20" MinHeight="14" Width="{Binding Hint.BoundingRectangle.Width}" Height="{Binding Hint.BoundingRectangle.Height}">
                            <TextBlock Text="{Binding Label}" FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="{Binding FontSizeReadValue}" Style="{StaticResource HintStyle}">
                            </TextBlock>
                        </Viewbox>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>
</local:ForegroundWindow>

