<local:ForegroundWindow
    x:Class="Vimium.Views.LineNavigationOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Vimium.Views"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    AllowsTransparency="True"
    Topmost="True"
    ShowActivated="False"
    Loaded="LineNavigationOverlayView_OnLoaded"
    Closed="LineNavigationOverlayView_OnClosed">
    <local:ForegroundWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Background" Value="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
            <Setter Property="Foreground" Value="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Active}" Value="false">
                    <Setter Property="Background" Value="{Binding DataContext.HintInactiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </local:ForegroundWindow.Resources>
    <local:ForegroundWindow.Background>
        <SolidColorBrush Color="Transparent" />
    </local:ForegroundWindow.Background>
    <Grid x:Name="layoutGrid" Background="Transparent" MouseDown="Overlay_MouseDown">
        <TextBox x:Name="MatchStringControl" IsReadOnly="True" IsHitTestVisible="False" Width="50" VerticalAlignment="Bottom" Background="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" Foreground="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}" FontWeight="Bold" FontFamily="Segoe UI, Helvetica, Arial" />
        <!-- Loading indicator: shown while hints are being enumerated on a background thread -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}"
                CornerRadius="3"
                Padding="12,8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Generating line hints…"
                           Foreground="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}"
                           FontSize="16"
                           FontWeight="Bold"
                           FontFamily="Segoe UI, Helvetica, Arial">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="TextBlock.Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.3" Duration="0:0:0.6" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Empty-state message: shown when no text lines were found -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{Binding DataContext.HintActiveBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}"
                CornerRadius="3"
                Padding="12,8"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                x:Name="EmptyMessageBorder">
            <TextBlock Text="{Binding EmptyMessage}"
                       Foreground="{Binding DataContext.HintTextBrush, RelativeSource={RelativeSource AncestorType=local:ForegroundWindow}}"
                       FontSize="16"
                       FontWeight="Bold"
                       FontFamily="Segoe UI, Helvetica, Arial" />
        </Border>
        <ItemsControl ItemsSource="{Binding Hints}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsItemsHost="True" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style>
                    <Setter Property="Canvas.Top" Value="{Binding Hint.BoundingRectangle.Top}" />
                    <Setter Property="Canvas.Left" Value="{Binding Hint.BoundingRectangle.Left}" />
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Viewbox StretchDirection="DownOnly" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1 1 0 0" Width="{Binding Hint.BoundingRectangle.Width}" Height="{Binding Hint.BoundingRectangle.Height}">
                            <TextBlock Text="{Binding Label}" FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="{Binding FontSizeReadValue}" Style="{StaticResource HintStyle}">
                            </TextBlock>
                        </Viewbox>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</local:ForegroundWindow>
