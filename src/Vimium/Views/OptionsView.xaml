<Window x:Class="Vimium.Views.OptionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Vimium.ViewModels"
        xmlns:c="clr-namespace:Vimium.Converters"
        xmlns:services="clr-namespace:Vimium.Services"
        Title="Vimium Settings" Height="600" Width="800"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <c:HexToColorConverter x:Key="HexToColorConverter" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- Page content templates — auto-selected by DataType -->

            <DataTemplate DataType="{x:Type vm:GeneralSettingsViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="General"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Font Size -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Font Size" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Controls the size of hint labels in the overlay."
                                           Style="{StaticResource DescriptionStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <ComboBox ItemsSource="{Binding FontSizes}"
                                              SelectedValue="{Binding FontSize}"
                                              Style="{StaticResource SettingComboBoxStyle}"
                                              Width="80" />
                                    <TextBlock Margin="16,6,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="Preview: "/>
                                        <Run Text="The quick brown fox…"
                                             FontSize="{Binding FontSize, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Theme -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Appearance" Style="{StaticResource SectionTitleStyle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Theme:" Style="{StaticResource SettingLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding Themes}"
                                              SelectedValue="{Binding Theme}"
                                              Style="{StaticResource SettingComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Language:" Style="{StaticResource SettingLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding Languages}"
                                              SelectedValue="{Binding Language}"
                                              Style="{StaticResource SettingComboBoxStyle}"
                                              IsEnabled="False" />
                                    <TextBlock Text="(more languages coming soon)"
                                               Style="{StaticResource DescriptionStyle}"
                                               Margin="12,6,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Administrator Mode -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Administrator Mode" Style="{StaticResource SectionTitleStyle}" />
                                <CheckBox Content="_Run as Administrator"
                                          IsChecked="{Binding RunAsAdministrator}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          FontSize="13" Margin="0,4,0,0" />
                                <TextBlock Text="Vimium will launch with elevated privileges. Requires a UAC prompt."
                                           Style="{StaticResource DescriptionStyle}"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="⚠ A restart is required for this change to take effect."
                                           Foreground="{DynamicResource WarningBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding ShowRestartMessage, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:OverlaySettingsViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Overlay"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Hint Colors -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Hint Colors" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Customise the background and text colors of hint labels."
                                           Style="{StaticResource DescriptionStyle}" />
                                <StackPanel Margin="0,8,0,0">
                                    <!-- Active background -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Label Content="Active:" Style="{StaticResource SettingLabelStyle}"
                                               Width="100" />
                                        <TextBox Text="{Binding HintActiveBackground, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource HexInputStyle}" />
                                        <Border Style="{StaticResource ColorSwatchStyle}"
                                                Background="{Binding HintActiveBackground, Converter={StaticResource HexToColorConverter}}" />
                                    </StackPanel>
                                    <!-- Inactive background -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Label Content="Inactive:" Style="{StaticResource SettingLabelStyle}"
                                               Width="100" />
                                        <TextBox Text="{Binding HintInactiveBackground, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource HexInputStyle}" />
                                        <Border Style="{StaticResource ColorSwatchStyle}"
                                                Background="{Binding HintInactiveBackground, Converter={StaticResource HexToColorConverter}}" />
                                    </StackPanel>
                                    <!-- Text color -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Label Content="Text:" Style="{StaticResource SettingLabelStyle}"
                                               Width="100" />
                                        <TextBox Text="{Binding HintTextColor, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource HexInputStyle}" />
                                        <Border Style="{StaticResource ColorSwatchStyle}"
                                                Background="{Binding HintTextColor, Converter={StaticResource HexToColorConverter}}" />
                                    </StackPanel>
                                    <!-- Preset swatches -->
                                    <StackPanel Orientation="Horizontal" Margin="100,4,0,0">
                                        <ItemsControl ItemsSource="{Binding PresetColors}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource PresetSwatchStyle}"
                                                            ToolTip="{Binding}"
                                                            Background="{Binding Converter={StaticResource HexToColorConverter}}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Animation -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Animation" Style="{StaticResource SectionTitleStyle}" />
                                <CheckBox Content="Show loading animation while hints are generated"
                                          IsChecked="{Binding HintAnimationEnabled}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          FontSize="13" Margin="0,4" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ActionSettingsViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Keyboard &amp; Actions"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,16" />

                        <!-- ── Activation Shortcuts ── -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Activation Shortcuts" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Configure which key combinations trigger the overlay."
                                           Style="{StaticResource DescriptionStyle}" />
                                <TextBlock Text="Format: Ctrl+; — modifiers: Ctrl, Alt, Shift, Win — key: letter, digit, or symbol."
                                           Style="{StaticResource DescriptionStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Label Content="Overlay:" Style="{StaticResource SettingLabelStyle}" Width="80" />
                                    <TextBox Text="{Binding OverlayModifier, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource HexInputStyle}" Width="120" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Taskbar:" Style="{StaticResource SettingLabelStyle}" Width="80" />
                                    <TextBox Text="{Binding TaskbarModifier, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource HexInputStyle}" Width="120" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Label Content="Find Text:" Style="{StaticResource SettingLabelStyle}" Width="80" />
                                    <TextBox Text="{Binding LineNavigationModifier, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource HexInputStyle}" Width="120" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Hint Actions ── -->
                        <Border Style="{StaticResource SettingsCardStyle}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Hint Actions" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Configure what happens when you select a hint. Slot 0 is the default (no modifier). Slots 1–2 use a modifier key (e.g. Shift, Ctrl+Alt). Mode: Hold = keep modifier held while typing hint. Type = press modifier, release, then type hint."
                                           Style="{StaticResource DescriptionStyle}"
                                           TextWrapping="Wrap" />

                                <!-- Slot 0 -->
                                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Slot 0 — Default (no modifier)" Style="{StaticResource SectionTitleStyle}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Action:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableActions}"
                                                      SelectedValue="{Binding Slot0Action, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="170" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Slot 1 -->
                                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Slot 1" Style="{StaticResource SectionTitleStyle}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Modifier:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <TextBox Text="{Binding Slot1Modifier, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource HexInputStyle}" Width="110" />
                                            <Label Content="Mode:" Style="{StaticResource SettingLabelStyle}" Width="50" Margin="10,0,0,0" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableModes}"
                                                      SelectedValue="{Binding Slot1Mode, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="80" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Action:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableActions}"
                                                      SelectedValue="{Binding Slot1Action, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="170" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Slot 2 -->
                                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Slot 2" Style="{StaticResource SectionTitleStyle}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Modifier:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <TextBox Text="{Binding Slot2Modifier, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource HexInputStyle}" Width="110" />
                                            <Label Content="Mode:" Style="{StaticResource SettingLabelStyle}" Width="50" Margin="10,0,0,0" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableModes}"
                                                      SelectedValue="{Binding Slot2Mode, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="80" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Action:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableActions}"
                                                      SelectedValue="{Binding Slot2Action, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="170" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Slot 3 -->
                                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Slot 3" Style="{StaticResource SectionTitleStyle}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Modifier:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <TextBox Text="{Binding Slot3Modifier, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource HexInputStyle}" Width="110" />
                                            <Label Content="Mode:" Style="{StaticResource SettingLabelStyle}" Width="50" Margin="10,0,0,0" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableModes}"
                                                      SelectedValue="{Binding Slot3Mode, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="80" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Label Content="Action:" Style="{StaticResource SettingLabelStyle}" Width="70" />
                                            <ComboBox ItemsSource="{x:Static vm:ActionSettingsViewModel.AvailableActions}"
                                                      SelectedValue="{Binding Slot3Action, Mode=TwoWay}"
                                                      Style="{StaticResource SettingComboBoxStyle}" Width="170" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <!-- ── Main Layout ─────────────────────────────────────── -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- App header in sidebar -->
                    <Border Padding="16,16">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding AppIcon, Source={x:Static services:ConfigService.Instance}}"
                                   Width="20" Height="20"
                                   Margin="0,0,8,0" />
                            <TextBlock Text="Vimium"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Navigation items -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Pages}"
                             SelectedItem="{Binding SelectedPage}"
                             ItemContainerStyle="{StaticResource SidebarItemStyle}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             x:Name="SidebarList"
                             KeyDown="SidebarList_KeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="16"
                                               Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding DisplayName}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Content area -->
            <ContentControl Grid.Column="1"
                            Content="{Binding SelectedPage}"
                            Background="{DynamicResource WindowBackgroundBrush}" />
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{DynamicResource FooterBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <!-- Version label (informational, not focusable) -->
                <TextBlock Text="{Binding AppVersion, StringFormat=v{0}}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="_Reset to defaults"
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="_Close"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsDefault="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
