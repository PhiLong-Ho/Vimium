<Application x:Class="Vimium.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightTheme.xaml" />
                <ResourceDictionary Source="Views/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Application icons: the active theme determines which is shown -->
            <BitmapImage x:Key="AppIcon" UriSource="/Resources/keyboard.ico" />
            <BitmapImage x:Key="FallbackIcon" UriSource="/Resources/keyboard.ico" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
