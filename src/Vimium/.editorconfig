# EditorConfig for the Vimium WPF application — analyzer rule tuning.
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/configuration-files

root = false

[*.cs]

# CA1822: "Member does not access instance data and can be marked as static."
# Disabled project-wide. In this MVVM/WPF app the flagged members are:
#   * View-model presentation properties (Icon, DisplayName, option lists, AppVersion)
#     that are data-bound in XAML via {Binding ...} — WPF resolves these against the
#     DataContext instance, so they MUST remain instance members or the binding breaks
#     silently at runtime. The analyzer cannot see XAML bindings.
#   * Service methods (e.g. ClipboardService.SetText) that are invoked on instances
#     (including from unit tests) and are intentionally instance members for DI/testability.
dotnet_diagnostic.CA1822.severity = none
