<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Override system colors so dropdowns are dark ─────── -->

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#152535" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#152535" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E8F4FF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E8F4FF" />

    <!-- ── Skadi Theme (Arknights) ────────────────────────── -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0D1B2A" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#152535" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8F4FF" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#90B8D8" />
    <SolidColorBrush x:Key="BorderBrush" Color="#253A50" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#0F1D2D" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0E1C2C" />
    <SolidColorBrush x:Key="SidebarActiveBackgroundBrush" Color="#1C3045" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4FC3F7" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1A2E42" />
    <SolidColorBrush x:Key="PresetSwatchBorderBrush" Color="#355070" />

    <!-- ── Overlay-specific brushes ──────────────────────── -->

    <SolidColorBrush x:Key="OverlayLoadingForegroundBrush" Color="#7BC8F0" />
    <SolidColorBrush x:Key="OverlayMatchStringForegroundBrush" Color="#E0F0FF" />

    <!-- ── Skadi loading icon ────────────────────────────── -->

    <BitmapImage x:Key="SkadiLoadingIcon" UriSource="/Resources/skadi.ico" />

    <!-- ── Implicit defaults ──────────────────────────────── -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
    </Style>

</ResourceDictionary>
