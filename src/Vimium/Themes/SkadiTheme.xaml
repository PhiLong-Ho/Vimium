<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Skadi Theme (Arknights) ────────────────────────── -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0D1B2A" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1B2838" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0F0FF" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7B9DBF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2A3F55" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#111D2B" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0F1E2E" />
    <SolidColorBrush x:Key="SidebarActiveBackgroundBrush" Color="#1A2E42" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4FC3F7" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1E3040" />
    <SolidColorBrush x:Key="PresetSwatchBorderBrush" Color="#3A5068" />

    <!-- ── Implicit text defaults ─────────────────────────── -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

</ResourceDictionary>
