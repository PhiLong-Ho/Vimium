<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Light Theme Palette ────────────────────────────── -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#E6E6E6" />
    <SolidColorBrush x:Key="SidebarActiveBackgroundBrush" Color="#DADADA" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PresetSwatchBorderBrush" Color="#CCCCCC" />

</ResourceDictionary>
