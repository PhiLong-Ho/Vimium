<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Dark Theme Palette ─────────────────────────────── -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8E8E8" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#999999" />
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E3E" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#252525" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#262626" />
    <SolidColorBrush x:Key="SidebarActiveBackgroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4CA1FF" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="PresetSwatchBorderBrush" Color="#555555" />

    <!-- ── Implicit text defaults (fixes unreadable text) ── -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

</ResourceDictionary>
