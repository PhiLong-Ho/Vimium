<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Dark Theme Palette ─────────────────────────────── -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0" />
    <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#202020" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#202020" />
    <SolidColorBrush x:Key="SidebarActiveBackgroundBrush" Color="#383838" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4CA1FF" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="PresetSwatchBorderBrush" Color="#505050" />

    <!-- ── Loading indicator icon ────────────────────────── -->

    <BitmapImage x:Key="SkadiLoadingIcon" UriSource="/Resources/skadi.ico" />

    <!-- ── Overlay-specific brushes ──────────────────────── -->

    <SolidColorBrush x:Key="OverlayLoadingForegroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="OverlayMatchStringForegroundBrush" Color="#F0F0F0" />

    <!-- ── Implicit defaults ──────────────────────────────── -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

</ResourceDictionary>
